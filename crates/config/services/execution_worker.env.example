DATABASE_URL=postgres://app:app@127.0.0.1:5432/azums
EXECUTION_DB_MAX_CONNECTIONS=8
EXECUTION_DB_ACQUIRE_TIMEOUT_SECS=5
EXECUTION_ALLOWED_ADAPTERS=adapter_solana
EXECUTION_DISPATCH_QUEUE=execution.dispatch
EXECUTION_CALLBACK_QUEUE=execution.callback
EXECUTION_WORKER_ID=execution-core-worker
EXECUTION_CALLBACK_WORKER_ID=execution-callback-worker
EXECUTION_LEASE_SECONDS=30
EXECUTION_BATCH_SIZE=32
EXECUTION_IDLE_SLEEP_MS=250
EXECUTION_REAP_INTERVAL_MS=5000
SOLANA_SYNC_MAX_POLLS=8
SOLANA_SYNC_POLL_DELAY_MS=1200
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_RPC_TIMEOUT_MS=10000

# Optional fallback callback dispatcher if no tenant destination is configured.
# EXECUTION_CALLBACK_DELIVERY_URL=https://example.com/callback
# EXECUTION_CALLBACK_DELIVERY_TOKEN=replace-me
# EXECUTION_CALLBACK_SIGNING_SECRET=replace-me
# EXECUTION_CALLBACK_SIGNING_KEY_ID=dev-key
# EXECUTION_CALLBACK_TIMEOUT_MS=10000
# EXECUTION_CALLBACK_ALLOW_PRIVATE_DESTINATIONS=false
# EXECUTION_CALLBACK_ALLOWED_HOSTS=example.com

# Optional Solana signing configuration.
# SOLANA_PAYER_SECRET_BASE58=replace-me
# SOLANA_PAYER_SECRET_FILE=/run/secrets/solana_payer_secret
# SOLANA_SIGN_SCRIPT=/workspace/scripts/solana-sign.sh
