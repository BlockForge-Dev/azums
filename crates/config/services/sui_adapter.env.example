# Sui transport + polling behavior
# Use ordered hybrid providers: external/managed first, self-hosted fallback second.
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
SUI_RPC_PRIMARY_URL=https://fullnode.mainnet.sui.io:443
SUI_RPC_FALLBACK_URLS=https://your-self-hosted-sui-rpc.example.com
SUI_RPC_URLS=https://fullnode.mainnet.sui.io:443,https://your-self-hosted-sui-rpc.example.com
SUI_RPC_TIMEOUT_MS=10000
SUI_SYNC_MAX_POLLS=12
SUI_SYNC_POLL_DELAY_MS=1200

# Execution mode
SUI_PLATFORM_SIGNING_ENABLED=false

# Future adapter notes:
# - customer-signed production should keep SUI_PLATFORM_SIGNING_ENABLED=false
# - receipts should record provider_used, rpc_urls, signing_mode, payer_source, fee_payer, tx_digest
# - failover should apply to broadcast, status polling, object/version fetch, and dry-run paths
