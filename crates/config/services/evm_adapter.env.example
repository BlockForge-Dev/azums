# EVM transport + polling behavior
# Use ordered hybrid providers: external/managed first, self-hosted fallback second.
EVM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/replace-me
EVM_RPC_PRIMARY_URL=https://eth-mainnet.g.alchemy.com/v2/replace-me
EVM_RPC_FALLBACK_URLS=https://your-self-hosted-evm-rpc.example.com
EVM_RPC_URLS=https://eth-mainnet.g.alchemy.com/v2/replace-me,https://your-self-hosted-evm-rpc.example.com
EVM_RPC_TIMEOUT_MS=10000
EVM_SYNC_MAX_POLLS=12
EVM_SYNC_POLL_DELAY_MS=1200

# Execution mode
EVM_PLATFORM_SIGNING_ENABLED=false

# Future adapter notes:
# - customer-signed production should keep EVM_PLATFORM_SIGNING_ENABLED=false
# - receipts should record provider_used, rpc_urls, signing_mode, payer_source, fee_payer, tx_hash
# - failover should apply to broadcast, receipt polling, nonce/block fetch, and simulation/call paths
