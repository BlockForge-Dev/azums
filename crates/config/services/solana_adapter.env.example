# Solana transport + polling behavior
SOLANA_RPC_URL=https://api.devnet.solana.com
# Optional ordered provider list for hybrid mode. First URL is primary, later URLs are failover.
# SOLANA_RPC_URLS=https://provider-a.example.com,https://provider-b.example.com
# SOLANA_RPC_PRIMARY_URL=https://provider-a.example.com
# SOLANA_RPC_FALLBACK_URLS=https://self-hosted-rpc.example.com
SOLANA_RPC_TIMEOUT_MS=10000
SOLANA_SYNC_MAX_POLLS=8
SOLANA_SYNC_POLL_DELAY_MS=1200
SOLANA_PLATFORM_SIGNING_ENABLED=true

# Optional compute budget controls
SOLANA_CU_LIMIT=200000
SOLANA_CU_PRICE_MICROLAMPORTS=1
SOLANA_CU_PRICE_MAX_MICROLAMPORTS=100000

# Signing material (choose one source)
# SOLANA_PAYER_SECRET_BASE58=replace-me
# SOLANA_PAYER_SECRET_FILE=/run/secrets/solana_payer_secret

# Optional external signing script path
# SOLANA_SIGN_SCRIPT=/workspace/scripts/solana-sign.sh
