# Platform database
POSTGRES_DB=azums
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgres://app:app@postgres:5432/azums

# Published ports
PROXY_HOST_PORT=8000
INGRESS_HOST_PORT=8081
STATUS_HOST_PORT=8082
OPERATOR_UI_HOST_PORT=8083

# Ingress API
INGRESS_DB_MAX_CONNECTIONS=8
INGRESS_BEARER_TOKEN=dev-ingress-token
INGRESS_PRINCIPAL_SUBMITTER_BINDINGS=ingress-service=internal_service
INGRESS_REQUIRE_PRINCIPAL_SUBMITTER_BINDING=true
INGRESS_PRINCIPAL_TENANT_BINDINGS=ingress-service=tenant_demo|tenant_ws_*
INGRESS_REQUIRE_PRINCIPAL_TENANT_BINDING=true
INGRESS_REQUIRE_PRINCIPAL_ID=true
INGRESS_REQUIRE_SUBMITTER_KIND=true
INGRESS_REQUIRE_API_KEY_FOR_API_KEY_HOLDER=true
INGRESS_API_ALLOWED_SUBMITTERS=api_key_holder,internal_service,wallet_backend
INGRESS_WEBHOOK_ALLOWED_SUBMITTERS=signed_webhook_sender,internal_service
INGRESS_INTENT_ROUTES=solana.transfer.v1=adapter_solana;solana.broadcast.v1=adapter_solana
INGRESS_INTENT_SCHEMAS=solana.transfer.v1=solana.transfer.v1;solana.broadcast.v1=solana.broadcast.v1
INGRESS_REQUIRE_SCHEMA_FOR_ALL_ROUTES=true
INGRESS_DEFAULT_QUOTA_PLAN=developer
INGRESS_DEFAULT_QUOTA_ACCESS_MODE=free_play
INGRESS_DEFAULT_FREE_PLAY_LIMIT=500
INGRESS_DEFAULT_EXECUTION_POLICY=sponsored
INGRESS_DEFAULT_SPONSORED_MONTHLY_CAP_REQUESTS=10000
INGRESS_EXECUTION_POLICY_ENFORCEMENT_ENABLED=false
INGRESS_EXECUTION_POLICY_CANARY_TENANTS=
OBS_ENV=dev
OBS_LOG_FILTER=info
OBS_LOG_JSON=false
OBS_METRICS_PREFIX=platform
OBS_REQUEST_ID_HEADER=x-request-id
OBS_CORRELATION_ID_HEADER=x-correlation-id

# Execution worker + queues
EXECUTION_DB_MAX_CONNECTIONS=8
EXECUTION_ALLOWED_ADAPTERS=adapter_solana
EXECUTION_DISPATCH_QUEUE=execution.dispatch
EXECUTION_CALLBACK_QUEUE=execution.callback
EXECUTION_WORKER_ID=execution-core-worker
EXECUTION_CALLBACK_WORKER_ID=execution-callback-worker
EXECUTION_LEASE_SECONDS=30
EXECUTION_BATCH_SIZE=32
EXECUTION_IDLE_SLEEP_MS=50
EXECUTION_REAP_INTERVAL_MS=5000
SOLANA_PLATFORM_SIGNING_ENABLED=true

# Status API
STATUS_API_DB_MAX_CONNECTIONS=8
STATUS_API_BEARER_TOKEN=dev-status-token
STATUS_API_REQUIRE_BEARER_AUTH=true
STATUS_API_PRINCIPAL_ROLE_BINDINGS=demo-operator=admin;workspace-*-owner=admin;workspace-*-admin=admin;workspace-*-developer=operator;workspace-*-viewer=viewer
STATUS_API_REQUIRE_PRINCIPAL_ROLE_BINDING=true
STATUS_API_PRINCIPAL_TENANT_BINDINGS=demo-operator=tenant_demo|tenant_ws_*;workspace-*=tenant_ws_*
STATUS_API_REQUIRE_PRINCIPAL_TENANT_BINDING=true
STATUS_API_REDACT_FAILURE_PROVIDER_DETAILS_FOR_VIEWER=true
STATUS_API_REDACT_CALLBACK_ERROR_DETAILS_FOR_VIEWER=true
STATUS_API_ENABLE_REPLAY=true
STATUS_API_REPLAY_DB_MAX_CONNECTIONS=4
STATUS_API_INTENT_ROUTES=solana.transfer.v1=adapter_solana;solana.broadcast.v1=adapter_solana
STATUS_API_ALLOWED_ADAPTERS=adapter_solana

# Operator UI
OPERATOR_UI_STATUS_BASE_URL=http://status-api:8082
OPERATOR_UI_STATUS_BEARER_TOKEN=dev-status-token
OPERATOR_UI_TENANT_ID=tenant_demo
OPERATOR_UI_PRINCIPAL_ID=demo-operator
OPERATOR_UI_PRINCIPAL_ROLE=admin
OPERATOR_UI_STATUS_PRINCIPAL_MODE=workspace
OPERATOR_UI_STATUS_TIMEOUT_MS=15000
OPERATOR_UI_INGRESS_BASE_URL=http://reverse-proxy:8000
OPERATOR_UI_INGRESS_BEARER_TOKEN=dev-ingress-token
OPERATOR_UI_INGRESS_PRINCIPAL_ID=ingress-service
OPERATOR_UI_INGRESS_SUBMITTER_KIND=internal_service
OPERATOR_UI_INGRESS_FALLBACK_PRINCIPAL_ID=
OPERATOR_UI_INGRESS_FALLBACK_SUBMITTER_KIND=
OPERATOR_UI_REQUIRE_DURABLE_METERING=false
OPERATOR_UI_ENFORCE_WORKSPACE_SOLANA_RPC=true
OPERATOR_UI_SANDBOX_SOLANA_RPC_URL=https://api.devnet.solana.com
OPERATOR_UI_STAGING_SOLANA_RPC_URL=
OPERATOR_UI_PRODUCTION_SOLANA_RPC_URL=
OPERATOR_UI_ACCOUNT_STORE_BACKEND=postgres
OPERATOR_UI_ACCOUNT_STORE_KEY=default
OPERATOR_UI_PUBLIC_BASE_URL=http://127.0.0.1:3000
OPERATOR_UI_RECONCILIATION_ROLLOUT_MODE=customer_visible
OPERATOR_UI_REQUIRE_EMAIL_VERIFICATION=false
OPERATOR_UI_PASSWORD_RESET_ENABLED=false
OPERATOR_UI_EMAIL_VERIFICATION_TTL_MS=86400000
OPERATOR_UI_PASSWORD_RESET_TTL_MS=1800000
OPERATOR_UI_EMAIL_FROM=no-reply@azums.local
# OPERATOR_UI_SMTP_HOST=smtp.example.com
# OPERATOR_UI_SMTP_PORT=587
# OPERATOR_UI_SMTP_USERNAME=example
# OPERATOR_UI_SMTP_PASSWORD=example
# OPERATOR_UI_FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST_xxx
# OPERATOR_UI_FLUTTERWAVE_WEBHOOK_HASH=flutterwave_webhook_hash
# OPERATOR_UI_FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3
# OPERATOR_UI_FLUTTERWAVE_EXPECTED_CURRENCY=
# OPERATOR_UI_FLUTTERWAVE_FX_RATES_USD=USD=1;NGN=0.00066;GBP=1.27;CAD=0.74;JPY=0.0067

# Reverse proxy
REVERSE_PROXY_PUBLIC_PATH_ACL_ENABLED=true
REVERSE_PROXY_STRIP_STATUS_PREFIX=true
REVERSE_PROXY_STRIP_API_PREFIX=false
REVERSE_PROXY_STRIP_WEBHOOKS_PREFIX=false

# Solana adapter/runtime
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_RPC_TIMEOUT_MS=10000
SOLANA_SYNC_MAX_POLLS=8
SOLANA_SYNC_POLL_DELAY_MS=1200

# Optional callback fallback destination for worker (tenant destination has precedence)
# EXECUTION_CALLBACK_DELIVERY_URL=https://example.com/callback
# EXECUTION_CALLBACK_DELIVERY_TOKEN=replace-me
# EXECUTION_CALLBACK_SIGNING_SECRET=replace-me
# EXECUTION_CALLBACK_SIGNING_KEY_ID=dev-key
# EXECUTION_CALLBACK_TIMEOUT_MS=10000
# EXECUTION_CALLBACK_ALLOW_PRIVATE_DESTINATIONS=false
# EXECUTION_CALLBACK_ALLOWED_HOSTS=example.com

# Optional signer config for Solana adapter
# SOLANA_PAYER_SECRET_BASE58=replace-me
# SOLANA_PAYER_SECRET_FILE=/run/secrets/solana_payer_secret
# SOLANA_SIGN_SCRIPT=/workspace/scripts/solana-sign.sh
